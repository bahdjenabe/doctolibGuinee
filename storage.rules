rules_version = '2';

// ============================================================
// RÈGLES DE SÉCURITÉ FIREBASE STORAGE — doctolibguinee
// ============================================================
//
// Arborescence :
//   documents/{uid}/{fichier}  → documents déposés par l'utilisateur
//                                 {uid} (patient ou médecin).
//
// Un utilisateur ne peut lire/écrire que dans son propre dossier.
// (Le partage médecin → patient se fait via une copie du fichier
//  dans le dossier du destinataire, ou via un lien signé.)
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    match /documents/{userId}/{fileName=**} {
      // Lecture réservée au propriétaire du dossier.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Écriture par le propriétaire, limitée à 10 Mo et aux formats
      // médicaux courants (PDF, images).
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('image/.*'));

      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
